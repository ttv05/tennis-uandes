{
  "buildCommand": "pnpm build:web",
  "outputDirectory": ".web",
  "framework": "expo",
  "env": {
    "EXPO_USE_METRO_WORKSPACE_ROOT": "1"
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
